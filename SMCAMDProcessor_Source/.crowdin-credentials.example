# Copy to .crowdin-credentials (gitignored) and fill in real values:
#   cp .crowdin-credentials.example .crowdin-credentials
#
# Get Project ID:
#   Crowdin project → Tools → API  (or Project Settings → API)
#   Numeric ID, e.g. 784291
#
# Get Personal Access Token:
#   Crowdin → Account Settings → API → New Token
#   Scopes: Projects (read/write), Source files & strings, Translations
#   Optional: limit token to this project only (Granular access)

CROWDIN_PROJECT_ID=YOUR_NUMERIC_PROJECT_ID
CROWDIN_PERSONAL_TOKEN=YOUR_PERSONAL_ACCESS_TOKEN
